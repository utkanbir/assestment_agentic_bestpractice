PREFIX aakp: <https://aakp.ai/ontology/assessment#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:  <http://www.w3.org/2001/XMLSchema#>

INSERT DATA {
  GRAPH <https://aakp.ai/graph/agents> {

    <https://aakp.ai/data/agent/kubernetes-agent>
        a aakp:AssessmentAgent ;
        aakp:hasAgentId      "kubernetes-agent" ;
        aakp:hasWorkstream   "kubernetes" ;
        aakp:hasDisplayName  "Kubernetes Assessment Agent" ;
        rdfs:label             "Kubernetes Assessment Agent" ;
        aakp:hasDescription  "K8s cluster mimarisi, guvenlik, HA ve observability degerlendirmesi" ;
        aakp:isActive        "true"^^xsd:boolean ;
        aakp:hasVersion      "sprint8" .

    <https://aakp.ai/data/agent/cloud-strategy-agent>
        a aakp:AssessmentAgent ;
        aakp:hasAgentId      "cloud-strategy-agent" ;
        aakp:hasWorkstream   "cloud_strategy" ;
        aakp:hasDisplayName  "Cloud Strategy Agent" ;
        rdfs:label             "Cloud Strategy Agent" ;
        aakp:hasDescription  "Kurumsal cloud donusum vizyonu, FinOps ve platform secimi degerlendirmesi" ;
        aakp:isActive        "true"^^xsd:boolean ;
        aakp:hasVersion      "sprint8" .

    <https://aakp.ai/data/agent/ingestion-agent>
        a aakp:AssessmentAgent ;
        aakp:hasAgentId      "ingestion-agent" ;
        aakp:hasWorkstream   "ingestion" ;
        aakp:hasDisplayName  "Data Ingestion Agent" ;
        rdfs:label             "Data Ingestion Agent" ;
        aakp:hasDescription  "NiFi, Kafka, DataStage -- gercek zamanli ve batch ingestion olgunlugu" ;
        aakp:isActive        "true"^^xsd:boolean ;
        aakp:hasVersion      "sprint8" .

    <https://aakp.ai/data/agent/teradata-dr-agent>
        a aakp:AssessmentAgent ;
        aakp:hasAgentId      "teradata-dr-agent" ;
        aakp:hasWorkstream   "teradata_dr" ;
        aakp:hasDisplayName  "Teradata DR Agent" ;
        rdfs:label             "Teradata DR Agent" ;
        aakp:hasDescription  "Teradata Vantage disaster recovery, backup ve is surekliligi degerlendirmesi" ;
        aakp:isActive        "true"^^xsd:boolean ;
        aakp:hasVersion      "sprint8" .

    <https://aakp.ai/data/agent/lakehouse-agent>
        a aakp:AssessmentAgent ;
        aakp:hasAgentId      "lakehouse-agent" ;
        aakp:hasWorkstream   "lakehouse" ;
        aakp:hasDisplayName  "Lakehouse Agent" ;
        rdfs:label             "Lakehouse Agent" ;
        aakp:hasDescription  "Databricks Delta Lake -- mimari, yonetisim ve ML platform olgunlugu" ;
        aakp:isActive        "true"^^xsd:boolean ;
        aakp:hasVersion      "sprint8" .

    <https://aakp.ai/data/agent/governance-agent>
        a aakp:AssessmentAgent ;
        aakp:hasAgentId      "governance-agent" ;
        aakp:hasWorkstream   "governance" ;
        aakp:hasDisplayName  "Data Governance Agent" ;
        rdfs:label             "Data Governance Agent" ;
        aakp:hasDescription  "OpenMetadata uzerinden veri sahipligi, kalitesi, lineage ve politika yonetimi" ;
        aakp:isActive        "true"^^xsd:boolean ;
        aakp:hasVersion      "sprint8" .

    <https://aakp.ai/data/agent/data-product-agent>
        a aakp:AssessmentAgent ;
        aakp:hasAgentId      "data-product-agent" ;
        aakp:hasWorkstream   "data_product" ;
        aakp:hasDisplayName  "Data Product Agent" ;
        rdfs:label             "Data Product Agent" ;
        aakp:hasDescription  "Veri urunu tanimi, SLA yonetimi ve self-serve analytics degerlendirmesi" ;
        aakp:isActive        "true"^^xsd:boolean ;
        aakp:hasVersion      "sprint8" .

    <https://aakp.ai/data/agent/cdp-agent>
        a aakp:AssessmentAgent ;
        aakp:hasAgentId      "cdp-agent" ;
        aakp:hasWorkstream   "cdp" ;
        aakp:hasDisplayName  "CDP Agent" ;
        rdfs:label             "CDP Agent" ;
        aakp:hasDescription  "Musteri veri platformu kimlik cozumleme, segmentasyon ve aktivasyon degerlendirmesi" ;
        aakp:isActive        "true"^^xsd:boolean ;
        aakp:hasVersion      "sprint8" .

  }
}
