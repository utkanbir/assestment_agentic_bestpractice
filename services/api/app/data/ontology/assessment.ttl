@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix aakp: <https://aakp.ai/ontology/assessment#> .

<https://aakp.ai/ontology/assessment>
    a owl:Ontology ;
    rdfs:label "AAKP Assessment Ontology" ;
    owl:versionInfo "0.4" .

# ─── Classes ────────────────────────────────────────────────────────────────

aakp:Assessment a owl:Class ; rdfs:label "Assessment" .
aakp:Task        a owl:Class ; rdfs:label "Task" .
aakp:Interview   a owl:Class ; rdfs:label "Interview" .
aakp:Question    a owl:Class ; rdfs:label "Question" .
aakp:Answer      a owl:Class ; rdfs:label "Answer" .
aakp:Evaluation  a owl:Class ; rdfs:label "Evaluation" .
aakp:Consultant  a owl:Class ; rdfs:label "Consultant" .
aakp:Evidence    a owl:Class ; rdfs:label "Evidence" .
aakp:Finding     a owl:Class ; rdfs:label "Finding" .
aakp:Report      a owl:Class ; rdfs:label "Report" .
aakp:TrainingInteraction a owl:Class ; rdfs:label "TrainingInteraction" .
aakp:AgentKnowledge      a owl:Class ; rdfs:label "AgentKnowledge" .
aakp:AssessmentAgent     a owl:Class ; rdfs:label "Assessment Agent" ;
    rdfs:comment "Workstream değerlendirme ajanı (Fuseki agent registry)" .
aakp:PracticeTheme       a owl:Class ; rdfs:label "PracticeTheme" ;
    rdfs:comment "Çapraz-workstream uygulama teması (ör. vendor independence, scalability)" .

# Evidence subclasses
aakp:InterviewEvidence     a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "InterviewEvidence" .
aakp:DocumentEvidence      a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "DocumentEvidence" .
aakp:MetricEvidence        a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "MetricEvidence" .
aakp:ArchitectureEvidence  a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "ArchitectureEvidence" .
aakp:ConfigurationEvidence a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "ConfigurationEvidence" .

# Status enumerations
aakp:AssessmentStatus a owl:Class ; rdfs:label "AssessmentStatus" .
aakp:Planning    a aakp:AssessmentStatus .
aakp:InProgress  a aakp:AssessmentStatus .
aakp:UnderReview a aakp:AssessmentStatus .
aakp:Complete    a aakp:AssessmentStatus .

aakp:TaskStatus       a owl:Class ; rdfs:label "TaskStatus" .
aakp:NotStarted       a aakp:TaskStatus .
aakp:FindingsCaptured a aakp:TaskStatus .

aakp:InterviewStatus a owl:Class ; rdfs:label "InterviewStatus" .
aakp:Scheduled   a aakp:InterviewStatus .
aakp:Completed   a aakp:InterviewStatus .
aakp:Cancelled   a aakp:InterviewStatus .

aakp:ReportType          a owl:Class ; rdfs:label "ReportType" .
aakp:TaskReport          a aakp:ReportType .
aakp:ExecutiveSummary    a aakp:ReportType .
aakp:RiskHeatmap         a aakp:ReportType .
aakp:ArchitectureRoadmap a aakp:ReportType .
aakp:MaturityReport      a aakp:ReportType .
aakp:GapAnalysis         a aakp:ReportType .

aakp:Confidence a owl:Class ; rdfs:label "Confidence" .
aakp:High   a aakp:Confidence .
aakp:Medium a aakp:Confidence .
aakp:Low    a aakp:Confidence .

aakp:Priority a owl:Class ; rdfs:label "Priority" .

# ─── Object Properties ───────────────────────────────────────────────────────

aakp:hasTask             a owl:ObjectProperty ; rdfs:domain aakp:Assessment ; rdfs:range aakp:Task .
aakp:hasFinding          a owl:ObjectProperty ; rdfs:domain aakp:Assessment ; rdfs:range aakp:Finding .
aakp:hasReport           a owl:ObjectProperty ; rdfs:range aakp:Report .
aakp:hasStatus           a owl:ObjectProperty .
aakp:belongsToAssessment a owl:ObjectProperty ; rdfs:domain aakp:Task ; rdfs:range aakp:Assessment .
aakp:hasInterview        a owl:ObjectProperty ; rdfs:domain aakp:Task ; rdfs:range aakp:Interview .
aakp:producesFinding     a owl:ObjectProperty ; rdfs:domain aakp:Task ; rdfs:range aakp:Finding .
aakp:dependsOnTask       a owl:ObjectProperty ; rdfs:domain aakp:Task ; rdfs:range aakp:Task .
aakp:conductedForTask    a owl:ObjectProperty ; rdfs:domain aakp:Interview ; rdfs:range aakp:Task .
aakp:hasQuestion         a owl:ObjectProperty ; rdfs:domain aakp:Interview ; rdfs:range aakp:Question .
aakp:suggestedQuestion   a owl:ObjectProperty ;
                           rdfs:subPropertyOf aakp:hasQuestion ;
                           rdfs:domain aakp:Interview ;
                           rdfs:range aakp:Question ;
                           rdfs:comment "Links an interview to a pending agent-suggested question awaiting approval." .
aakp:producesEvidence    a owl:ObjectProperty ; rdfs:domain aakp:Interview ; rdfs:range aakp:Evidence .
aakp:hasAnswer           a owl:ObjectProperty ; rdfs:domain aakp:Question ; rdfs:range aakp:Answer .
aakp:hasConsultant       a owl:ObjectProperty ; rdfs:domain aakp:Assessment ; rdfs:range aakp:Consultant .
aakp:reviewedByConsultant a owl:ObjectProperty ; rdfs:domain aakp:Answer ; rdfs:range aakp:Consultant .
aakp:hasEvaluation       a owl:ObjectProperty ; rdfs:domain aakp:Answer ; rdfs:range aakp:Evaluation .
aakp:answersQuestion     a owl:ObjectProperty ; rdfs:domain aakp:Answer ; rdfs:range aakp:Question .
aakp:supportsEvidence    a owl:ObjectProperty ; rdfs:domain aakp:Answer ; rdfs:range aakp:Evidence .
aakp:supportsFinding     a owl:ObjectProperty ; rdfs:domain aakp:Evidence ; rdfs:range aakp:Finding .
aakp:supportedByEvidence a owl:ObjectProperty ; rdfs:domain aakp:Finding ; rdfs:range aakp:Evidence .
aakp:relatedToFinding    a owl:ObjectProperty ; rdfs:domain aakp:Finding ; rdfs:range aakp:Finding .
aakp:generatedFor        a owl:ObjectProperty ; rdfs:domain aakp:Report .
aakp:containsFinding     a owl:ObjectProperty ; rdfs:domain aakp:Report ; rdfs:range aakp:Finding .

# Used by kg_writer — Finding points back to its Task
aakp:identifiedInTask    a owl:ObjectProperty ; rdfs:domain aakp:Finding ; rdfs:range aakp:Task .
# Used by kg_writer — Evidence points back to its Interview
aakp:collectedInInterview a owl:ObjectProperty ; rdfs:domain aakp:Evidence ; rdfs:range aakp:Interview .

# ─── Datatype Properties ─────────────────────────────────────────────────────

# Shared
aakp:hasTitle        a owl:DatatypeProperty ; rdfs:range xsd:string .
aakp:pgId            a owl:DatatypeProperty ; rdfs:range xsd:string ; rdfs:comment "PostgreSQL UUID bridge" .
aakp:hasCreatedAt    a owl:DatatypeProperty ; rdfs:range xsd:dateTime .

# Assessment
aakp:hasClientName   a owl:DatatypeProperty ; rdfs:domain aakp:Assessment ; rdfs:range xsd:string .
aakp:hasProjectName  a owl:DatatypeProperty ; rdfs:domain aakp:Assessment ; rdfs:range xsd:string .
aakp:isSimulated     a owl:DatatypeProperty ; rdfs:domain aakp:Assessment ; rdfs:range xsd:boolean .
aakp:assessmentMode  a owl:DatatypeProperty ; rdfs:domain aakp:Assessment ; rdfs:range xsd:string .

# Task
aakp:hasAgentType    a owl:DatatypeProperty ; rdfs:domain aakp:Task ; rdfs:range xsd:string .
aakp:hasWorkstream   a owl:DatatypeProperty ; rdfs:domain aakp:Task ; rdfs:range xsd:string .
aakp:hasScope        a owl:DatatypeProperty ; rdfs:domain aakp:Task ; rdfs:range xsd:string .

# Interview
aakp:hasSource       a owl:DatatypeProperty ; rdfs:range xsd:string .
aakp:hasCategory     a owl:DatatypeProperty ; rdfs:range xsd:string .
aakp:conductedAt     a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
aakp:durationMinutes a owl:DatatypeProperty ; rdfs:range xsd:integer .
aakp:intervieweeName a owl:DatatypeProperty ; rdfs:domain aakp:Interview ; rdfs:range xsd:string .
aakp:intervieweeRole a owl:DatatypeProperty ; rdfs:domain aakp:Interview ; rdfs:range xsd:string .

# Question / Answer
aakp:hasText           a owl:DatatypeProperty ; rdfs:range xsd:string .
aakp:hasOrder          a owl:DatatypeProperty ; rdfs:domain aakp:Question ; rdfs:range xsd:integer .
aakp:isAgentSuggested      a owl:DatatypeProperty ; rdfs:domain aakp:Question ; rdfs:range xsd:boolean .
aakp:questionApprovalStatus a owl:DatatypeProperty ;
                              rdfs:domain aakp:Question ;
                              rdfs:range xsd:string ;
                              rdfs:comment "Values: pending | approved | rejected. Default approved for consultant questions, pending for agent suggestions." .

# Evaluation
aakp:evaluationText a owl:DatatypeProperty ; rdfs:domain aakp:Evaluation ; rdfs:range xsd:string .

# Consultant
aakp:firstName          a owl:DatatypeProperty ; rdfs:domain aakp:Consultant ; rdfs:range xsd:string .
aakp:lastName           a owl:DatatypeProperty ; rdfs:domain aakp:Consultant ; rdfs:range xsd:string .
aakp:consultantRole     a owl:DatatypeProperty ; rdfs:domain aakp:Consultant ; rdfs:range xsd:string .
aakp:consultantExpertise  a owl:DatatypeProperty ; rdfs:domain aakp:Consultant ; rdfs:range xsd:string .
aakp:consultantComment  a owl:DatatypeProperty ; rdfs:domain aakp:Answer ; rdfs:range xsd:string .

# Evidence
aakp:content      a owl:DatatypeProperty ; rdfs:domain aakp:Evidence ; rdfs:range xsd:string .
aakp:capturedAt   a owl:DatatypeProperty ; rdfs:range xsd:dateTime .

# Finding
aakp:description     a owl:DatatypeProperty ; rdfs:domain aakp:Finding ; rdfs:range xsd:string .
aakp:hasConfidence   a owl:DatatypeProperty ; rdfs:domain aakp:Finding ; rdfs:range xsd:decimal .
aakp:approvalStatus  a owl:DatatypeProperty ; rdfs:domain aakp:Finding ; rdfs:range xsd:string .
aakp:isInvalid       a owl:DatatypeProperty ; rdfs:domain aakp:Finding ; rdfs:range xsd:boolean ;
                       rdfs:comment "Rule 7: true when no supportedByEvidence exists" .

# Report
aakp:generatedAt  a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
aakp:reportTitle  a owl:DatatypeProperty ; rdfs:domain aakp:Report ; rdfs:range xsd:string .
aakp:executiveSummary a owl:DatatypeProperty ; rdfs:domain aakp:Report ; rdfs:range xsd:string .

# Agent training (S24)
aakp:trainingMode     a owl:DatatypeProperty ; rdfs:domain aakp:TrainingInteraction ; rdfs:range xsd:string .
aakp:trainingQuestion a owl:DatatypeProperty ; rdfs:domain aakp:TrainingInteraction ; rdfs:range xsd:string .
aakp:trainingAnswer   a owl:DatatypeProperty ; rdfs:domain aakp:TrainingInteraction ; rdfs:range xsd:string .
aakp:answerAuthor     a owl:DatatypeProperty ; rdfs:domain aakp:TrainingInteraction ; rdfs:range xsd:string .
aakp:knowledgeContent a owl:DatatypeProperty ; rdfs:domain aakp:AgentKnowledge ; rdfs:range xsd:string .
aakp:knowledgeMode    a owl:DatatypeProperty ; rdfs:domain aakp:AgentKnowledge ; rdfs:range xsd:string .
aakp:sourceDocId      a owl:DatatypeProperty ; rdfs:domain aakp:AgentKnowledge ; rdfs:range xsd:string .
aakp:sourceFilename   a owl:DatatypeProperty ; rdfs:domain aakp:AgentKnowledge ; rdfs:range xsd:string .
aakp:forWorkstream    a owl:DatatypeProperty ; rdfs:range xsd:string .
aakp:hasTrainingEvent a owl:ObjectProperty ; rdfs:range aakp:TrainingInteraction .
aakp:hasAgentKnowledge a owl:ObjectProperty ; rdfs:range aakp:AgentKnowledge .
aakp:refersToConcept   a owl:ObjectProperty ;
    rdfs:range  owl:Thing ;
    rdfs:comment "Eğitim kaydının bağlandığı domain kavramı (arch:Capability veya aakp:PracticeTheme)" .

# Agent registry (S3)
aakp:hasAgentId     a owl:DatatypeProperty ; rdfs:domain aakp:AssessmentAgent ; rdfs:range xsd:string .
aakp:hasDisplayName a owl:DatatypeProperty ; rdfs:domain aakp:AssessmentAgent ; rdfs:range xsd:string .
aakp:hasDescription a owl:DatatypeProperty ; rdfs:domain aakp:AssessmentAgent ; rdfs:range xsd:string .
aakp:isActive       a owl:DatatypeProperty ; rdfs:domain aakp:AssessmentAgent ; rdfs:range xsd:boolean .
aakp:hasVersion     a owl:DatatypeProperty ; rdfs:domain aakp:AssessmentAgent ; rdfs:range xsd:string .
