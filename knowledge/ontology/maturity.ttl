@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix aakp: <https://aakp.ai/ontology/assessment#> .
@prefix arch: <https://aakp.ai/ontology/architecture#> .
@prefix mat:  <https://aakp.ai/ontology/maturity#> .

<https://aakp.ai/ontology/maturity>
    a owl:Ontology ;
    owl:imports <https://aakp.ai/ontology/assessment>, <https://aakp.ai/ontology/architecture> ;
    rdfs:label "AAKP Maturity Ontology" ;
    owl:versionInfo "0.3" .

# ─── Classes ────────────────────────────────────────────────────────────────

mat:Gap            a owl:Class ; rdfs:label "Gap" .
mat:Risk           a owl:Class ; rdfs:label "Risk" .
mat:Recommendation a owl:Class ; rdfs:label "Recommendation" .
mat:MaturityScore  a owl:Class ; rdfs:label "MaturityScore" .
mat:Roadmap        a owl:Class ; rdfs:label "Roadmap" .
mat:RoadmapItem    a owl:Class ; rdfs:label "RoadmapItem" .

mat:Severity  a owl:Class ; rdfs:label "Severity" .
mat:Critical  a mat:Severity ; rdfs:label "critical" .
mat:High      a mat:Severity ; rdfs:label "high" .
mat:Medium    a mat:Severity ; rdfs:label "medium" .
mat:Low       a mat:Severity ; rdfs:label "low" .
mat:Info      a mat:Severity ; rdfs:label "info" .

mat:Horizon    a owl:Class ; rdfs:label "Horizon" .
mat:ShortTerm  a mat:Horizon ; rdfs:label "Short Term (0-3 months)" .
mat:MediumTerm a mat:Horizon ; rdfs:label "Medium Term (3-12 months)" .
mat:LongTerm   a mat:Horizon ; rdfs:label "Long Term (12+ months)" .

mat:MaturityDimension a owl:Class ; rdfs:label "MaturityDimension" .
mat:People     a mat:MaturityDimension ; rdfs:label "People" .
mat:Process    a mat:MaturityDimension ; rdfs:label "Process" .
mat:Technology a mat:MaturityDimension ; rdfs:label "Technology" .
mat:Data       a mat:MaturityDimension ; rdfs:label "Data" .

# ─── Object Properties ───────────────────────────────────────────────────────

mat:affectsCapability    a owl:ObjectProperty ; rdfs:range arch:Capability .
mat:causedByGap          a owl:ObjectProperty ; rdfs:domain mat:Risk ; rdfs:range mat:Gap .
mat:hasSeverity          a owl:ObjectProperty ; rdfs:domain mat:Risk ; rdfs:range mat:Severity .
mat:addressesGap         a owl:ObjectProperty ; rdfs:domain mat:Recommendation ; rdfs:range mat:Gap .
mat:mitigatesRisk        a owl:ObjectProperty ; rdfs:domain mat:Recommendation ; rdfs:range mat:Risk .
mat:improvesCapability   a owl:ObjectProperty ; rdfs:domain mat:Recommendation ; rdfs:range arch:Capability .
mat:hasHorizon           a owl:ObjectProperty ; rdfs:range mat:Horizon .
mat:hasPriority          a owl:ObjectProperty .
mat:isPartOfRoadmap      a owl:ObjectProperty ; rdfs:domain mat:Recommendation ; rdfs:range mat:RoadmapItem .
mat:belongsToCapability  a owl:ObjectProperty ; rdfs:domain mat:MaturityScore ; rdfs:range arch:Capability .
mat:hasDimension         a owl:ObjectProperty ; rdfs:domain mat:MaturityScore ; rdfs:range mat:MaturityDimension .
mat:generatedFor         a owl:ObjectProperty ; rdfs:domain mat:Roadmap .
mat:hasRoadmapItem       a owl:ObjectProperty ; rdfs:domain mat:Roadmap ; rdfs:range mat:RoadmapItem .
mat:partOfRoadmap        a owl:ObjectProperty ; rdfs:domain mat:RoadmapItem ; rdfs:range mat:Roadmap .
mat:implementsRecommendation a owl:ObjectProperty ; rdfs:domain mat:RoadmapItem ; rdfs:range mat:Recommendation .
mat:dependsOnItem        a owl:ObjectProperty ; rdfs:domain mat:RoadmapItem ; rdfs:range mat:RoadmapItem .

# Cross-graph: Finding → maturity concepts
mat:indicatesGap         a owl:ObjectProperty ; rdfs:domain aakp:Finding ; rdfs:range mat:Gap .
mat:indicatesRisk        a owl:ObjectProperty ; rdfs:domain aakp:Finding ; rdfs:range mat:Risk .

# Finding ← Risk (reverse direction for chain traversal)
mat:derivedFromFinding   a owl:ObjectProperty ; rdfs:domain mat:Risk ; rdfs:range aakp:Finding .

# ─── Datatype Properties ─────────────────────────────────────────────────────

# Shared label/description
mat:hasTitle       a owl:DatatypeProperty ; rdfs:range xsd:string .
mat:hasDescription a owl:DatatypeProperty ; rdfs:range xsd:string .
mat:pgId           a owl:DatatypeProperty ; rdfs:range xsd:string ; rdfs:comment "PostgreSQL UUID bridge" .

# MaturityScore
mat:hasLevel         a owl:DatatypeProperty ; rdfs:domain mat:MaturityScore ; rdfs:range xsd:decimal ;
                       rdfs:comment "0.0 (initial) to 5.0 (optimised)" .
mat:hasJustification a owl:DatatypeProperty ; rdfs:domain mat:MaturityScore ; rdfs:range xsd:string .

# Risk
mat:hasSeverityValue a owl:DatatypeProperty ; rdfs:domain mat:Risk ; rdfs:range xsd:string ;
                       rdfs:comment "String copy of severity for direct querying: critical/high/medium/low" .
mat:hasImpact        a owl:DatatypeProperty ; rdfs:domain mat:Risk ; rdfs:range xsd:string .
mat:hasLikelihood    a owl:DatatypeProperty ; rdfs:domain mat:Risk ; rdfs:range xsd:string .

# Gap
mat:hasCapabilityArea    a owl:DatatypeProperty ; rdfs:domain mat:Gap ; rdfs:range xsd:string .
mat:inferredConfidence   a owl:DatatypeProperty ; rdfs:domain mat:Gap ; rdfs:range xsd:decimal ;
                           rdfs:comment "Rule 5: max confidence from approved Findings that indicatesGap this gap" .

# Recommendation / RoadmapItem
mat:hasPriorityValue  a owl:DatatypeProperty ; rdfs:range xsd:integer .
mat:estimatedEffort   a owl:DatatypeProperty ; rdfs:domain mat:RoadmapItem ; rdfs:range xsd:string .

# Cross-task risk propagation (S4-KA-001 — Rule 6)
mat:propagatedToTask  a owl:ObjectProperty ;
    rdfs:domain mat:Risk ;
    rdfs:range  aakp:Task ;
    rdfs:comment "Rule 6: Risk propagated from a dependency task via aakp:dependsOnTask" .

mat:propagatedFromTask a owl:ObjectProperty ;
    rdfs:domain mat:Risk ;
    rdfs:range  aakp:Task ;
    rdfs:comment "Rule 6: Source task from which this risk was propagated" .

mat:isPropagated a owl:DatatypeProperty ;
    rdfs:domain mat:Risk ;
    rdfs:range  xsd:boolean ;
    rdfs:comment "Rule 6: true when risk is inferred via cross-task dependency, not directly observed" .

# ─── Inference Rules ─────────────────────────────────────────────────────────
#
# Rule 5 (confidence propagation) — implemented in reasoner config
#   IF Finding hasConfidence C AND Finding indicatesGap G
#   THEN G inferredConfidence MAX(C, existing_inferredConfidence)
#
# Rule 6 (cross-task risk propagation) — SPARQL CONSTRUCT or reasoner
#   IF TaskA dependsOnTask TaskB
#   AND TaskB producesFinding F
#   AND F indicatesRisk R
#   AND R hasSeverityValue "critical"
#   THEN R propagatedToTask TaskA
#        R isPropagated true
#
# Rule 7 (unsupported finding invalid) — implemented in SHACL + LangGraph edge
#   IF Finding NOT supportedByEvidence E
#   THEN Finding isInvalid true
