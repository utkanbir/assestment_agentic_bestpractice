@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix aakp: <https://aakp.ai/ontology/assessment#> .
@prefix arch: <https://aakp.ai/ontology/architecture#> .
@prefix org:  <https://aakp.ai/ontology/organization#> .

<https://aakp.ai/ontology/organization>
    a owl:Ontology ;
    owl:imports <https://aakp.ai/ontology/assessment>, <https://aakp.ai/ontology/architecture> ;
    rdfs:label "AAKP Organization Ontology" ;
    owl:versionInfo "0.2" .

# ─── Classes ────────────────────────────────────────────────────────────────

org:Organization  a owl:Class ; rdfs:label "Organization" .
org:BusinessUnit  a owl:Class ; rdfs:label "BusinessUnit" .
org:Stakeholder   a owl:Class ; rdfs:label "Stakeholder" .
org:Owner         a owl:Class ; rdfs:subClassOf org:Stakeholder ; rdfs:label "Owner" .
org:Steward       a owl:Class ; rdfs:subClassOf org:Stakeholder ; rdfs:label "Steward" .

# ─── Object Properties ───────────────────────────────────────────────────────

org:ownsCapability       a owl:ObjectProperty ; rdfs:domain org:BusinessUnit ; rdfs:range arch:Capability .
org:belongsToBusinessUnit a owl:ObjectProperty ; rdfs:domain org:Stakeholder ; rdfs:range org:BusinessUnit .
org:ownsDataProduct      a owl:ObjectProperty ; rdfs:domain org:Stakeholder ; rdfs:range arch:DataProduct .
org:participatesInInterview a owl:ObjectProperty ; rdfs:domain org:Stakeholder ; rdfs:range aakp:Interview .
org:facilitatedBy        a owl:ObjectProperty ; rdfs:domain aakp:Interview ; rdfs:range org:Stakeholder .
org:participatedBy       a owl:ObjectProperty ; rdfs:domain aakp:Interview ; rdfs:range org:Stakeholder .
org:hasCustomer          a owl:ObjectProperty ; rdfs:domain aakp:Assessment ; rdfs:range org:Organization .
org:providedBy           a owl:ObjectProperty ; rdfs:domain aakp:Answer ; rdfs:range org:Stakeholder .
