@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix aakp: <https://aakp.ai/ontology/assessment#> .

<https://aakp.ai/ontology/assessment>
    a owl:Ontology ;
    rdfs:label "AAKP Assessment Ontology" ;
    owl:versionInfo "0.2" .

# ─── Classes ────────────────────────────────────────────────────────────────

aakp:Assessment a owl:Class ; rdfs:label "Assessment" .
aakp:Task        a owl:Class ; rdfs:label "Task" .
aakp:Interview   a owl:Class ; rdfs:label "Interview" .
aakp:Question    a owl:Class ; rdfs:label "Question" .
aakp:Answer      a owl:Class ; rdfs:label "Answer" .
aakp:Evidence    a owl:Class ; rdfs:label "Evidence" .
aakp:Finding     a owl:Class ; rdfs:label "Finding" .
aakp:Report      a owl:Class ; rdfs:label "Report" .

# Evidence subclasses
aakp:InterviewEvidence     a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "InterviewEvidence" .
aakp:DocumentEvidence      a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "DocumentEvidence" .
aakp:MetricEvidence        a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "MetricEvidence" .
aakp:ArchitectureEvidence  a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "ArchitectureEvidence" .
aakp:ConfigurationEvidence a owl:Class ; rdfs:subClassOf aakp:Evidence ; rdfs:label "ConfigurationEvidence" .

# Status enumerations
aakp:AssessmentStatus a owl:Class ; rdfs:label "AssessmentStatus" .
aakp:Planning    a aakp:AssessmentStatus .
aakp:InProgress  a aakp:AssessmentStatus .
aakp:UnderReview a aakp:AssessmentStatus .
aakp:Complete    a aakp:AssessmentStatus .

aakp:TaskStatus     a owl:Class ; rdfs:label "TaskStatus" .
aakp:NotStarted     a aakp:TaskStatus .
aakp:FindingsCaptured a aakp:TaskStatus .

aakp:InterviewStatus a owl:Class ; rdfs:label "InterviewStatus" .
aakp:Scheduled   a aakp:InterviewStatus .
aakp:Completed   a aakp:InterviewStatus .
aakp:Cancelled   a aakp:InterviewStatus .

aakp:ReportType      a owl:Class ; rdfs:label "ReportType" .
aakp:TaskReport      a aakp:ReportType .
aakp:ExecutiveSummary a aakp:ReportType .
aakp:RiskHeatmap     a aakp:ReportType .
aakp:ArchitectureRoadmap a aakp:ReportType .
aakp:MaturityReport  a aakp:ReportType .
aakp:GapAnalysis     a aakp:ReportType .

aakp:Confidence a owl:Class ; rdfs:label "Confidence" .
aakp:High   a aakp:Confidence .
aakp:Medium a aakp:Confidence .
aakp:Low    a aakp:Confidence .

aakp:Priority a owl:Class ; rdfs:label "Priority" .

# ─── Object Properties ───────────────────────────────────────────────────────

aakp:hasTask            a owl:ObjectProperty ; rdfs:domain aakp:Assessment ; rdfs:range aakp:Task .
aakp:hasFinding         a owl:ObjectProperty ; rdfs:domain aakp:Assessment ; rdfs:range aakp:Finding .
aakp:hasReport          a owl:ObjectProperty ; rdfs:range aakp:Report .
aakp:hasStatus          a owl:ObjectProperty .
aakp:belongsToAssessment a owl:ObjectProperty ; rdfs:domain aakp:Task ; rdfs:range aakp:Assessment .
aakp:hasInterview       a owl:ObjectProperty ; rdfs:domain aakp:Task ; rdfs:range aakp:Interview .
aakp:producesFinding    a owl:ObjectProperty ; rdfs:domain aakp:Task ; rdfs:range aakp:Finding .
aakp:dependsOnTask      a owl:ObjectProperty ; rdfs:domain aakp:Task ; rdfs:range aakp:Task .
aakp:conductedForTask   a owl:ObjectProperty ; rdfs:domain aakp:Interview ; rdfs:range aakp:Task .
aakp:hasQuestion        a owl:ObjectProperty ; rdfs:domain aakp:Interview ; rdfs:range aakp:Question .
aakp:producesEvidence   a owl:ObjectProperty ; rdfs:domain aakp:Interview ; rdfs:range aakp:Evidence .
aakp:hasAnswer          a owl:ObjectProperty ; rdfs:domain aakp:Question ; rdfs:range aakp:Answer .
aakp:answersQuestion    a owl:ObjectProperty ; rdfs:domain aakp:Answer ; rdfs:range aakp:Question .
aakp:supportsEvidence   a owl:ObjectProperty ; rdfs:domain aakp:Answer ; rdfs:range aakp:Evidence .
aakp:supportsFinding    a owl:ObjectProperty ; rdfs:domain aakp:Evidence ; rdfs:range aakp:Finding .
aakp:supportedByEvidence a owl:ObjectProperty ; rdfs:domain aakp:Finding ; rdfs:range aakp:Evidence .
aakp:relatedToFinding   a owl:ObjectProperty ; rdfs:domain aakp:Finding ; rdfs:range aakp:Finding .
aakp:hasConfidence      a owl:ObjectProperty ; rdfs:range aakp:Confidence .
aakp:generatedFor       a owl:ObjectProperty ; rdfs:domain aakp:Report .
aakp:containsFinding    a owl:ObjectProperty ; rdfs:domain aakp:Report ; rdfs:range aakp:Finding .

# ─── Datatype Properties ─────────────────────────────────────────────────────

aakp:hasSource       a owl:DatatypeProperty ; rdfs:range xsd:string .
aakp:hasCategory     a owl:DatatypeProperty ; rdfs:range xsd:string .
aakp:conductedAt     a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
aakp:capturedAt      a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
aakp:durationMinutes a owl:DatatypeProperty ; rdfs:range xsd:integer .
aakp:generatedAt     a owl:DatatypeProperty ; rdfs:range xsd:dateTime .
aakp:pgId            a owl:DatatypeProperty ; rdfs:range xsd:string ; rdfs:comment "PostgreSQL UUID link" .
