@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix aakp: <https://aakp.ai/ontology/assessment#> .
@prefix mat:  <https://aakp.ai/ontology/maturity#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ─── Risk Shape ──────────────────────────────────────────────────────────────
# mat:Risk must trace back to an aakp:Finding (derivedFromFinding)
# and carry at minimum a severity value and description.

<https://aakp.ai/shapes/RiskShape>
    a sh:NodeShape ;
    sh:targetClass mat:Risk ;
    sh:name "RiskShape" ;
    sh:description "Every Risk must derive from a Finding and have severity + description." ;

    # Risk MUST reference its source Finding
    sh:property [
        sh:path     mat:derivedFromFinding ;
        sh:minCount 1 ;
        sh:class    aakp:Finding ;
        sh:message  "Risk must reference an aakp:Finding via mat:derivedFromFinding." ;
        sh:severity sh:Violation ;
    ] ;

    # human-readable title (generated by LLM risk_reasoner)
    sh:property [
        sh:path     mat:hasTitle ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 3 ;
        sh:message  "Risk must have a non-empty title (mat:hasTitle)." ;
        sh:severity sh:Violation ;
    ] ;

    # description is mandatory
    sh:property [
        sh:path     mat:hasDescription ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "Risk must have a description (mat:hasDescription)." ;
        sh:severity sh:Violation ;
    ] ;

    # severity string: critical | high | medium | low
    sh:property [
        sh:path     mat:hasSeverityValue ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:in       ( "critical" "high" "medium" "low" ) ;
        sh:message  "Risk severity must be one of: critical, high, medium, low." ;
        sh:severity sh:Violation ;
    ] ;

    # PostgreSQL UUID bridge — must be present so we can join back to PG
    sh:property [
        sh:path     mat:pgId ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "Risk must carry mat:pgId (PostgreSQL UUID) for cross-store joins." ;
        sh:severity sh:Warning ;
    ] .


# ─── Recommendation Shape ───────────────────────────────────────────────────
# mat:Recommendation must address a Gap or mitigate a Risk (at least one),
# carry a description and a priority value.

<https://aakp.ai/shapes/RecommendationShape>
    a sh:NodeShape ;
    sh:targetClass mat:Recommendation ;
    sh:name "RecommendationShape" ;
    sh:description "Recommendation must target a Gap or Risk and carry description + priority." ;

    # description is mandatory
    sh:property [
        sh:path     mat:hasDescription ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "Recommendation must have a description (mat:hasDescription)." ;
        sh:severity sh:Violation ;
    ] ;

    # priority: 1 = highest urgency
    sh:property [
        sh:path     mat:hasPriorityValue ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:maxInclusive 5 ;
        sh:message  "Recommendation priority must be an integer 1-5 (1 = highest)." ;
        sh:severity sh:Violation ;
    ] ;

    # must address a gap OR mitigate a risk — enforced via sh:or
    sh:or (
        [
            sh:property [
                sh:path     mat:addressesGap ;
                sh:minCount 1 ;
                sh:class    mat:Gap ;
            ]
        ]
        [
            sh:property [
                sh:path     mat:mitigatesRisk ;
                sh:minCount 1 ;
                sh:class    mat:Risk ;
            ]
        ]
    ) ;

    sh:message "Recommendation must address at least one Gap (mat:addressesGap) or mitigate a Risk (mat:mitigatesRisk)." ;
    sh:severity sh:Warning .


# ─── Evidence Shape extension ────────────────────────────────────────────────
# Extends finding_shapes.ttl EvidenceShape with evidence_type enum constraint.
# SHACL allows multiple shapes targeting the same class — both will be checked.

<https://aakp.ai/shapes/EvidenceTypeShape>
    a sh:NodeShape ;
    sh:targetClass aakp:Evidence ;
    sh:name "EvidenceTypeShape" ;
    sh:description "Evidence type must be one of the four controlled values." ;

    sh:property [
        sh:path     aakp:hasCategory ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:in       ( "interview" "document" "observation" "metric" ) ;
        sh:message  "Evidence type must be: interview | document | observation | metric." ;
        sh:severity sh:Violation ;
    ] .
